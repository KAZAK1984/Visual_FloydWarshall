<Window x:Class="Visual_FloydWarshall.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Visual_FloydWarshall"
		mc:Ignorable="d"
		Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!-- Определения столбцов и строк -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="128*" />
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="333*" />
            <ColumnDefinition Width="333*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="0.4*" />
        </Grid.RowDefinitions>

        <!-- Левая панель инструментов -->
        <StackPanel Grid.Column="0" 
                    Grid.Row="0" 
                    Background="SeaShell" Grid.ColumnSpan="2">
            <TextBlock FontWeight="Bold" Margin="5">Инструменты</TextBlock>
            <Button Content="Загрузить граф" Margin="5,11,10,10"/>
            <Button Content="Рассчитать пути" Margin="5,0,10,0"/>
        </StackPanel>

        <!-- Центральная панель основной отрисовки -->
        <Canvas Grid.Column="1" 
				Grid.Row="0" 
				Background="LightGray" Grid.ColumnSpan="3" Margin="6,0,333,0">
            <TextBlock Margin="5">Граф (Визуализация)</TextBlock>
        </Canvas>

        <!-- Правая панель вторичной отрисовки -->
        <Canvas Grid.Column="3" 
				Grid.Row="0" 
				Background="LightGray">
            <TextBlock Margin="5">Матрица расстояний D</TextBlock>
        </Canvas>

        <!-- Панель хронологии (нижняя) -->
        <DockPanel Grid.Column="0" 
                   Grid.ColumnSpan="4" 
                   Background="SeaShell" Margin="0,310,0,0" Grid.RowSpan="2">
            <TextBlock DockPanel.Dock="Top" Margin="5">Хронология шагов (k)</TextBlock>
            <Slider Minimum="0" 
                    Maximum="20" 
                    TickFrequency="1" 
                    IsSnapToTickEnabled="True" 
                    Margin="20,0"/>
        </DockPanel>

        <!-- Разделители -->
        <Border Grid.Column="0" 
				Grid.Row="0" 
				BorderThickness="0,0,3,0" 
				BorderBrush="DarkGray" Grid.ColumnSpan="2" />

        <Border Grid.Column="0" 
				Grid.ColumnSpan="4"
				BorderThickness="0,3,0,0" 
				BorderBrush="DarkGray" Margin="0,310,0,0" Grid.RowSpan="2" />

        <GridSplitter Grid.Column="2" 
					  Grid.Row="0"  
					  Width="6" 
					  Background="DimGray"
					  HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="328,0,0,0" />
    </Grid>
</Window>
