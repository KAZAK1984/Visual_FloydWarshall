<Window x:Class="Visual_FloydWarshall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visual_FloydWarshall"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0.4*" />
        </Grid.RowDefinitions>
        
        <GridSplitter Grid.Column="2"  Grid.Row="0" ShowsPreview="False" Width="3"
            HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <Canvas Grid.Column="0" Grid.Row="0" Background="SeaShell">
            <TextBlock>Панель инструментов</TextBlock>
        </Canvas>
        <Canvas Grid.Column="1" Grid.Row="0" Background="LightGray">
            <TextBlock>Панель основной отрисовки</TextBlock>
        </Canvas>
        <Canvas Grid.Column="2" Grid.Row="0" Background="Black" />
        <Canvas Grid.Column="3" Grid.Row="0" Background="LightGray">
            <TextBlock>Панель вторичной отрисовки</TextBlock>
        </Canvas>

        <Canvas Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="4" Background="Coral">
            <TextBlock>Панель хронологии</TextBlock>
        </Canvas>
    </Grid>
</Window>
