<Window x:Class="Visual_FloydWarshall.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:util="clr-namespace:Visual_FloydWarshall.Utility"
		mc:Ignorable="d"
		Title="MainWindow" 
		MinHeight="600"
		MinWidth="800">
	<Window.Resources>
		<util:SubtractOneConverter x:Key="SubtractOneConverter"/>
	</Window.Resources>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="0.4*" />
			<ColumnDefinition Width="*" MinWidth="100" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" MinWidth="100" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="0.4*" />
		</Grid.RowDefinitions>

        <!-- Верхнее меню -->
		<Menu Grid.Row="0" Grid.ColumnSpan="4">
            
			<MenuItem Header="Файл">
				<MenuItem Header="Сохранить" Click="SaveMenuItem_Click" />
				<MenuItem Header="Загрузить" Click="LoadMenuItem_Click" />
			</MenuItem>
            
			<MenuItem Header="Алгоритм">
				<MenuItem Header="Описание" Click="ShowDescriptionMenuItem_Click" />
             <MenuItem Header="Как читать визуализацию" Click="ShowVisualizationGuideMenuItem_Click" />
			</MenuItem>
            
		</Menu>

		<!-- Левая панель инструментов -->
		<Border Grid.Column="0" 
                Grid.Row="1"
				BorderBrush="DarkGray" 
				BorderThickness="0,0,0,3"
				d:IsLocked="True">

			<Grid Background="SeaShell">

				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0" FontWeight="Bold" Margin="5,0"> Инструменты </TextBlock>

				<Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="5,5,7,5">
					<StackPanel Background="WhiteSmoke">

                        <Border BorderBrush="Gray" BorderThickness="0,0,0,1">
                            <TextBlock TextWrapping="Wrap" Margin="5"> Основное </TextBlock>
                        </Border>

                        <Button Click="CalculatePaths_Click" Content="Рассчитать пути" Margin="5"/>

                        <Button Click="CreateGraph_Click" Content="Создать граф" Margin="5"/>
						
                        <TextBlock TextWrapping="Wrap" Margin="5,0,5,2"> Кол-во вершин графа </TextBlock>
						<TextBox x:Name="VertexCountTextBox"
                                 TextWrapping="Wrap" Text="10" Margin="5,0,5,5" 
                                 util:TextBoxBehavior.NumericOnly="True"
                                 util:TextBoxBehavior.MinValue="4"
                                 util:TextBoxBehavior.MaxValue="40"/>
                        
					</StackPanel>
				</Border>

                <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="5,5,7,5">
                    <StackPanel Background="WhiteSmoke">

                        <Border BorderBrush="Gray" BorderThickness="0,0,0,1">
							<TextBlock TextWrapping="Wrap" Margin="5"> Дополнительное </TextBlock>
                        </Border>

                        <TextBlock TextWrapping="Wrap" Margin="5,5,5,2"> Узел отсчёта </TextBlock>
                        <TextBox x:Name="CalculateStartPos"
                                 KeyDown="VertexSelection_KeyDown"
                                 TextWrapping="Wrap" Text="0" Margin="5,0,5,5" 
								 util:TextBoxBehavior.NumericOnly="True"
								 util:TextBoxBehavior.MinValue="0"
								 util:TextBoxBehavior.MaxValue="{Binding Text, ElementName=VertexCountTextBox, Converter={StaticResource SubtractOneConverter}}"/>

                        <TextBlock TextWrapping="Wrap" Margin="5,0,5,2"> Целевой узел </TextBlock>
                        <TextBox x:Name="CalculateEndPos"
                                 KeyDown="VertexSelection_KeyDown"
                                 TextWrapping="Wrap" Text="1" Margin="5,0,5,5" 
								 util:TextBoxBehavior.NumericOnly="True"
								 util:TextBoxBehavior.MinValue="0"
                                util:TextBoxBehavior.MaxValue="{Binding Text, ElementName=VertexCountTextBox, Converter={StaticResource SubtractOneConverter}}"/>
                        
                    </StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- Центральная панель основной отрисовки -->
		<Border Grid.Column="1" 
                Grid.Row="1"
				BorderBrush="DarkGray" 
				BorderThickness="3,0,0,3"
				d:IsLocked="True">

            <Canvas x:Name="MainCanvas"  
					Background="LightGray" 
					SizeChanged="MainCanvas_SizeChanged"
					d:IsLocked="True">
				<TextBlock Margin="5">Граф (Визуализация)</TextBlock>
			</Canvas>
            
		</Border>

		<!-- Разделитель -->
		<GridSplitter Grid.Column="2" 
                   Grid.Row="1" 
					  Width="4"
					  Background="DimGray"
					  HorizontalAlignment="Center"
					  VerticalAlignment="Stretch"
					  d:IsLocked="True"/>
		
		<!-- Правая панель вторичной отрисовки -->
		<Border Grid.Column="3" 
                Grid.Row="1"
				BorderBrush="DarkGray" 
				BorderThickness="0,0,0,3"
				d:IsLocked="True">

          <ScrollViewer x:Name="DistanceMatrixScrollViewer"
						  HorizontalScrollBarVisibility="Auto"
						  VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="DistanceMatrixCanvas" 
                     Background="LightGray"
						MinWidth="{Binding ViewportWidth, ElementName=DistanceMatrixScrollViewer}"
						MinHeight="{Binding ViewportHeight, ElementName=DistanceMatrixScrollViewer}"
						d:IsLocked="True">
					<TextBlock Margin="11">Матрица расстояний D</TextBlock>
				</Canvas>
                
			</ScrollViewer>
		</Border>

		<!-- Панель хронологии (нижняя) -->
		<Grid Grid.Column="0" 
              Grid.Row="2"
			  Grid.ColumnSpan="4" 
			  Background="SeaShell" 
			  d:IsLocked="True">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="5,5,5,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" VerticalAlignment="Center">Ручной выбор шага циклов</TextBlock>
				<Button Grid.Column="1"
						Content="Следующая операция (k,i,j)"
						Padding="10,2"
						Margin="8,0,0,0"
						Click="NextOperation_Click"/>
			</Grid>

			<Grid Grid.Row="1" Margin="10,0,10,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">k:</TextBlock>
				<Slider x:Name="LoopKSlider"
						Grid.Column="1"
						Minimum="0"
						Maximum="0"
						TickFrequency="1"
						IsSnapToTickEnabled="True"
						ValueChanged="LoopSlider_ValueChanged"/>
				<TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding Value, ElementName=LoopKSlider, StringFormat=F0}"/>
			</Grid>

			<Grid Grid.Row="2" Margin="10,0,10,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">i:</TextBlock>
				<Slider x:Name="LoopISlider"
						Grid.Column="1"
						Minimum="0"
						Maximum="0"
						TickFrequency="1"
						IsSnapToTickEnabled="True"
						ValueChanged="LoopSlider_ValueChanged"/>
				<TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding Value, ElementName=LoopISlider, StringFormat=F0}"/>
			</Grid>

			<Grid Grid.Row="3" Margin="10,0,10,6">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">j:</TextBlock>
				<Slider x:Name="LoopJSlider"
						Grid.Column="1"
						Minimum="0"
						Maximum="0"
						TickFrequency="1"
						IsSnapToTickEnabled="True"
						ValueChanged="LoopSlider_ValueChanged"/>
				<TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding Value, ElementName=LoopJSlider, StringFormat=F0}"/>
			</Grid>

            <DataGrid x:Name="CalculationTable"
                    Grid.Row="4"
					  Margin="10,0,10,10"
					  IsReadOnly="True"
					  HeadersVisibility="Column"
					  AutoGenerateColumns="False">
                
                <DataGrid.Columns>
					<DataGridTextColumn Header="k" Binding="{Binding Step}" Width="0.2*"/>
                    <DataGridTextColumn Header="i" Binding="{Binding From}" Width="0.2*"/>
                    <DataGridTextColumn Header="j" Binding="{Binding To}" Width="0.2*"/>
					<DataGridTextColumn Header="OldD" Binding="{Binding OldDistance}" Width="*"/>
					<DataGridTextColumn Header="NewD" Binding="{Binding NewDistance}" Width="*"/>
                    <DataGridTextColumn Header="OldP" Binding="{Binding OldPredecessor}" Width="*"/>
                    <DataGridTextColumn Header="NewP" Binding="{Binding NewPredecessor}" Width="*"/>
				</DataGrid.Columns>
                
			</DataGrid>
            
		</Grid>
        
	</Grid>
</Window>
